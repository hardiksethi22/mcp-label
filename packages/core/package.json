{
  "name": "@mcp-label/core",
  "version": "0.1.4",
  "description": "Core types, schemas, analysis, scoring, and exporters for mcp-label",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hardiksethi22/mcp-label.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/hardiksethi22/mcp-label#readme",
  "bugs": {
    "url": "https://github.com/hardiksethi22/mcp-label/issues"
  },
  "keywords": ["mcp", "model-context-protocol", "security", "permissions", "label", "core"]
}
