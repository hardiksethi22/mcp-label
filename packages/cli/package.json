{
  "name": "@mcp-label/cli",
  "version": "0.1.3",
  "description": "CLI for mcp-label — a privacy, safety, and permissions label for MCP servers",
  "type": "module",
  "bin": {
    "mcp-label": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mcp-label/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
