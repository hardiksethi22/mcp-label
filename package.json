{
  "name": "mcp-label-monorepo",
  "private": true,
  "version": "0.1.3",
  "description": "A privacy, safety, and permissions label for Model Context Protocol servers.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml,yml}\"",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hardiksethi22/mcp-label.git"
  },
  "homepage": "https://github.com/hardiksethi22/mcp-label#readme",
  "bugs": {
    "url": "https://github.com/hardiksethi22/mcp-label/issues"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
